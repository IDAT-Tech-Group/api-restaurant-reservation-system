# ---------------------------------------------------------------
# CONFIGURACIÓN GENERAL DE LA APLICACIÓN
# ---------------------------------------------------------------
APP_NAME=Laravel           # Nombre de la aplicación (aparece en correos y logs)
APP_ENV=local              # Entorno: local | staging | production
APP_KEY=                   # Clave de cifrado AES-256. Generar con: php artisan key:generate
APP_DEBUG=true             # true muestra errores detallados (solo en desarrollo)
APP_URL=http://localhost    # URL base de la aplicación

# ---------------------------------------------------------------
# REGISTRO DE EVENTOS (LOGS)
# ---------------------------------------------------------------
LOG_CHANNEL=stack          # Canal de log: stack | single | daily | slack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug            # Nivel mínimo a registrar: debug | info | warning | error

# ---------------------------------------------------------------
# BASE DE DATOS
# Configurar con los datos del servidor MySQL de XAMPP
# ---------------------------------------------------------------
DB_CONNECTION=mysql        # Motor de BD: mysql | pgsql | sqlite
DB_HOST=127.0.0.1          # Host del servidor de base de datos
DB_PORT=3306               # Puerto de MySQL (por defecto 3306)
DB_DATABASE=laravel        # Nombre de la base de datos a usar
DB_USERNAME=root           # Usuario de MySQL (XAMPP usa 'root' por defecto)
DB_PASSWORD=               # Contraseña de MySQL (XAMPP no tiene contraseña por defecto)

# ---------------------------------------------------------------
# DRIVERS DE SERVICIOS INTERNOS
# ---------------------------------------------------------------
BROADCAST_DRIVER=log       # Driver para eventos en tiempo real (log = sin WebSockets)
CACHE_DRIVER=file          # Dónde se guarda el caché: file | redis | memcached
FILESYSTEM_DISK=local      # Disco de almacenamiento de archivos: local | s3
QUEUE_CONNECTION=sync      # Cola de trabajos: sync (inmediato) | database | redis
SESSION_DRIVER=file        # Dónde se guardan las sesiones: file | cookie | database
SESSION_LIFETIME=120       # Duración de la sesión en minutos

# ---------------------------------------------------------------
# MEMCACHED (caché en memoria, no usado en desarrollo local)
# ---------------------------------------------------------------
MEMCACHED_HOST=127.0.0.1

# ---------------------------------------------------------------
# REDIS (caché y colas en memoria, no usado en desarrollo local)
# ---------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------
# CORREO ELECTRÓNICO
# En desarrollo se usa Mailpit (http://localhost:8025) para interceptar correos
# En producción cambiar a un proveedor real (SMTP, Mailgun, SES, etc.)
# ---------------------------------------------------------------
MAIL_MAILER=smtp                          # Driver de correo: smtp | mailgun | ses | log
MAIL_HOST=mailpit                         # Host del servidor SMTP (Mailpit en local)
MAIL_PORT=1025                            # Puerto SMTP de Mailpit
MAIL_USERNAME=null                        # Usuario SMTP (no requerido en Mailpit)
MAIL_PASSWORD=null                        # Contraseña SMTP (no requerido en Mailpit)
MAIL_ENCRYPTION=null                      # Cifrado: tls | ssl | null
MAIL_FROM_ADDRESS="hello@example.com"     # Dirección remitente por defecto
MAIL_FROM_NAME="${APP_NAME}"              # Nombre remitente (usa el APP_NAME)

# ---------------------------------------------------------------
# AMAZON S3 (almacenamiento en la nube, no usado en este proyecto)
# Completar solo si se usa S3 como disco de archivos
# ---------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------
# PUSHER (WebSockets para eventos en tiempo real, no usado en este proyecto)
# Completar solo si se requiere broadcasting en tiempo real
# ---------------------------------------------------------------
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# Variables de Pusher expuestas al frontend (Vite las inyecta en el JS del cliente)
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
